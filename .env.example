# Google Cloud Platform Configuration
GCP_PROJECT_ID=your-project-id

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key

# Authentication Configuration
AUTH_ENABLED=true
AUTH_DEV_BYPASS=false
API_KEYS_SECRET_PATH=api-keys
DEV_API_KEY=your-dev-key-here
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Security & Abuse Prevention Configuration
SECURITY_ENABLED=true
FINGERPRINTING_ENABLED=true
VPN_DETECTION_ENABLED=true
BEHAVIOR_ANALYSIS_ENABLED=true
CAPTCHA_ENABLED=true
RATE_LIMITING_ENABLED=true
ABUSE_MONITORING_ENABLED=true

# Risk Assessment Thresholds
HIGH_RISK_THRESHOLD=0.7
CAPTCHA_THRESHOLD=0.5
BLOCK_THRESHOLD=0.9

# Rate Limiting Configuration
TRIAL_CREATION_PER_IP_PER_HOUR=3
TRIAL_CREATION_PER_FINGERPRINT_PER_HOUR=1
IMAGE_GENERATION_PER_MINUTE=2

# VPN Detection APIs (Optional - improves accuracy)
IPQUALITYSCORE_API_KEY=your-ipqualityscore-key
PROXYCHECK_API_KEY=your-proxycheck-key
VPN_DETECTION_TIMEOUT=5
VPN_CACHE_DURATION=3600
VPN_DETECTION_PAID_APIS=false

# CAPTCHA Services (Optional - for human verification)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
CAPTCHA_API_TIMEOUT=10

# GeoIP Database (Optional - for enhanced IP analysis)
GEOIP_DATABASE_PATH=/path/to/GeoLite2-City.mmdb

# Abuse Monitoring & Alerting
ABUSE_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
ABUSE_ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
ABUSE_ALERT_EMAIL_WEBHOOK=https://your-email-service.com/webhook

# Redis Configuration (Optional - for enhanced rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Database Configuration
FIRESTORE_EMULATOR_HOST=localhost:8080  # For local development only

# Development Settings
DEBUG=false
LOG_LEVEL=INFO